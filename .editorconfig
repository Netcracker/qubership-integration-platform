root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.xml]
indent_size = 2

[*.{js,jsx,mjs,ts,tsx,mts,json,css,scss}]
indent_size = 2

[*.html]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
# Markdown indentation is semantic (driven by list-marker width), not a fixed grid.
# Unset disables editorconfig-checker's "indent must be multiple of N" check for .md.
indent_size = unset

[*.sh]
# shfmt: indent case branches and keep the space in `>> file` redirects.
switch_case_indent = true
space_redirects = true

[Makefile]
indent_style = tab

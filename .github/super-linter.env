# Super-linter environment overrides.
# Loaded by .github/workflows/super-linter.yaml before the lint step runs.
#
# TypeScript/JavaScript linting is delegated to per-module `npm run lint` jobs
# in ui-build.yaml and vscode-extension-build.yaml so that ESLint runs with the
# module's own flat config and locally installed plugins (@typescript-eslint,
# eslint-plugin-react, eslint-plugin-jest, etc.). Super-linter's containerised
# ESLint cannot resolve these per-module plugins or apply the type-aware rules
# that need each module's tsconfig.json via parserOptions.projectService.
#
# Super-linter still validates YAML, shell, markdown, Dockerfile, JSON, and
# GitHub Actions workflows — everything where it doesn't need project-specific
# tooling.

# Point markdownlint at our config. Super-linter's default MARKDOWN_CONFIG_FILE
# is .markdown-lint.yml; without this it ignores .github/linters/.markdownlint.json
# and falls back to its built-in defaults (line_length 400, MD007 on).
MARKDOWN_CONFIG_FILE=.markdownlint.json

VALIDATE_JAVASCRIPT_ES=false
VALIDATE_JAVASCRIPT_STANDARD=false
VALIDATE_JSX=false
VALIDATE_TSX=false
VALIDATE_TYPESCRIPT_ES=false
VALIDATE_TYPESCRIPT_STANDARD=false

# Prettier is owned by per-module tooling: ui and vscode-extension run Prettier on
# their own src via their .prettierrc. Super-linter's repo-wide Prettier would
# reformat hundreds of functional files it doesn't own — Spring application.yml,
# JSON Schemas, and test fixtures — imposing a foreign style (double quotes,
# de-indented sequences). Language validators (yamllint, jsonlint, etc.) stay on;
# only the Prettier formatters are disabled.
VALIDATE_CSS_PRETTIER=false
VALIDATE_GRAPHQL_PRETTIER=false
VALIDATE_HTML_PRETTIER=false
VALIDATE_JAVASCRIPT_PRETTIER=false
VALIDATE_JSONC_PRETTIER=false
VALIDATE_JSON_PRETTIER=false
VALIDATE_JSX_PRETTIER=false
VALIDATE_MARKDOWN_PRETTIER=false
VALIDATE_TYPESCRIPT_PRETTIER=false
VALIDATE_VUE_PRETTIER=false
VALIDATE_YAML_PRETTIER=false

# Java formatting is enforced by Checkstyle (JAVA linter), not Google Java Format.
# JSCPD copy-paste detection is too noisy for the existing codebase.
VALIDATE_CHECKOV=false
VALIDATE_GOOGLE_JAVA_FORMAT=false
VALIDATE_JSCPD=false

# SQL in the repo is only Flyway migrations — immutable once applied (reformatting
# breaks Flyway's per-file checksum on existing DBs). SQLFluff's findings here are
# cosmetic-only and can't be acted on, so linting them adds no value.
VALIDATE_SQLFLUFF=false

# Exclude generated, vendored, and build output trees.
FILTER_REGEX_EXCLUDE=(^|/)(node_modules|dist|dist-lib|target|coverage|build)/.*

# Super-linter environment overrides.
# Loaded by .github/workflows/super-linter.yaml before the lint step runs.
#
# TypeScript/JavaScript linting is delegated to per-module `npm run lint` jobs
# in ui-build.yaml and vscode-extension-build.yaml so that ESLint runs with the
# module's own flat config and locally installed plugins (@typescript-eslint,
# eslint-plugin-react, eslint-plugin-jest, etc.). Super-linter's containerised
# ESLint cannot resolve these per-module plugins or apply the type-aware rules
# that need each module's tsconfig.json via parserOptions.projectService.
#
# Super-linter still validates YAML, shell, markdown, Dockerfile, JSON, and
# GitHub Actions workflows — everything where it doesn't need project-specific
# tooling.

VALIDATE_TYPESCRIPT_ES=false
VALIDATE_TYPESCRIPT_STANDARD=false
VALIDATE_JAVASCRIPT_ES=false
VALIDATE_JAVASCRIPT_STANDARD=false
VALIDATE_JSX=false
VALIDATE_TSX=false

# Exclude generated, vendored, and build output trees.
FILTER_REGEX_EXCLUDE=(^|/)(node_modules|dist|dist-lib|target|coverage|build)/.*

<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property resource="application.yml"/>

    <springProperty scope="context" name="logFormat" source="logging.format" defaultValue="json"/>
    <property name="appenderName_json" value="STDOUT_JSON" />
    <property name="appenderName_text" value="STDOUT" />
    <property name="appenderName" value="${appenderName_${logFormat}:-STDOUT_JSON}" />

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">

        <!-- Filter for Quartz Scheduler, very simple 'fix' -->
        <filter class="org.qubership.integration.platform.engine.camel.scheduler.CamelJobLogFilter"/>

         <encoder>
             <pattern>
                 [%d{yyyy-MM-dd'T'HH:mm:ss.SSS}] [%-5p] [request_id=%-15X{requestId:--}] [thread=%-15.15t] [class=%-60.60c{59}] [traceId=%-16X{X-B3-TraceId:--}] [spanId=%-16X{X-B3-SpanId:--}] [method=%-30.30M] [log_type=%-3X{logType:--}] [session_id=%-36X{internalProperty_sessionId:--}] [chain_id=%-36X{chainId:--}] [chain=%-30X{chainName:--}] [chain_element_id=%-36X{elementId:--}] [chain_element=%-15X{elementName:--}] - %m%n
             </pattern>
         </encoder>
     </appender>

    <appender name="STDOUT_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="org.qubership.integration.platform.engine.camel.scheduler.CamelJobLogFilter" />
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp>
                    <fieldName>time</fieldName>
                    <pattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</pattern>
                </timestamp>
                <logLevel>
                    <fieldName>level</fieldName>
                </logLevel>
                <message>
                    <fieldName>message</fieldName>
                </message>
                <threadName>
                    <fieldName>thread</fieldName>
                </threadName>
                <loggerName>
                    <fieldName>class</fieldName>
                </loggerName>
                <callerData>
                    <methodFieldName>method</methodFieldName>
                    <classFieldName>[ignore]</classFieldName>
                    <fileFieldName>[ignore]</fileFieldName>
                    <lineFieldName>[ignore]</lineFieldName>
                </callerData>
                <pattern>
                    <pattern>
                        {
                        "request_id": "%.-15X{requestId:--}",
                        "traceId": "%.-16X{X-B3-TraceId:--}",
                        "spanId": "%.-16X{X-B3-SpanId:--}",
                        "log_type": "%.-3X{logType:--}",
                        "session_id": "%.-36X{internalProperty_sessionId:--}",
                        "chain_id": "%.-36X{chainId:--}",
                        "chain": "%.-30X{chainName:--}",
                        "chain_element_id": "%.-36X{elementId:--}",
                        "chain_element": "%.-15X{elementName:--}"
                        }
                    </pattern>
                </pattern>
                <logstashMarkers />
                <stackTrace>
                    <fieldName>stacktrace</fieldName>
                </stackTrace>
            </providers>
        </encoder>
    </appender>

     <logger name="org.qubership.integration.platform.engine.service.debugger.logging.ChainLogger" level="INFO" additivity="false">
         <appender-ref ref="STDOUT"/>
     </logger>

     <logger name="org.qubership.integration.platform.engine.service.debugger.logging.JsonChainLogger" level="INFO" additivity="false">
         <appender-ref ref="STDOUT_JSON"/>
     </logger>

     <logger name="io.atlasmap.core.AtlasPath" level="ERROR">
         <appender-ref ref="${appenderName}"/>
     </logger>

    <logger name="Hibernate Types" level="ERROR">
        <appender-ref ref="${appenderName}"/>
    </logger>

     <root>
         <appender-ref ref="${appenderName}"/>
     </root>
 </configuration>

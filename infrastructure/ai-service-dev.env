# QIP AI Service (Quarkus) — local compose profile `ai`
# Copy to .env.local or export secrets before: docker compose --profile ai up

QUARKUS_HTTP_PORT=8080
CATALOG_URL=http://runtime-catalog:8080
CATALOG_TOKEN=

LLM_API_KEY=dev-placeholder
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=180s
LLM_EMBEDDING_MODEL=text-embedding-3-small

CHAT_MEMORY_MAX_TOKENS=24000

APIHUB_MCP_URL=
APIHUB_MCP_API_KEY=

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Create bucket on startup when MinIO is reachable.
STORAGE_INIT_BUCKET_ON_STARTUP=true

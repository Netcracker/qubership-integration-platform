{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>Netcracker/qubership-renovate-config",
    "security:only-security-updates"
  ],
  "packageRules": [
    {
      "description": "Pin GitHub Actions to commit SHAs and keep the pinned digests current",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["pin", "pinDigest", "digest"],
      "enabled": true
    }
  ]
}

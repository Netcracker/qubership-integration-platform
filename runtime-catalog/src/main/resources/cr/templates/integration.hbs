---
apiVersion: camel.apache.org/v1
kind: Integration
metadata:
  name: {{name}}
  labels:
    {{domainLabel}}: {{domainName}}
    {{bgVersionLabel}}: {{bgVersion}}
spec:
  replicas: {{replicas}}
  serviceAccountName: {{serviceAccountName}}
  traits:
    owner:
      targetLabels:
      - {{domainLabel}}
      - {{bgVersionLabel}}
    container:
{{#with container}}      image: "{{image}}"
      imagePullPolicy: {{imagePullPolicy}}
{{#with limit as | limit |}}
{{#if limit.cpu}}
      limitCPU: {{limit.cpu}}
{{/if}}
{{#if limit.memory}}
      limitMemory: {{limit.memory}}
{{/if}}
{{/with}}
{{#with request as | request |}}
{{#if request.cpu }}
      requestCPU: {{request.cpu}}
{{/if}}
{{#if request.memory }}
      requestMemory: {{request.memory}}
{{/if}}
{{/with}}
{{#if runAsUser}}
      runAsUser: {{runAsUser}}
{{/if}}
      runAsNonRoot: {{runAsNonRoot}}
      seccompProfileType: {{seccompProfileType}}
      allowPrivilegeEscalation: {{allowPrivilegeEscalation}}
{{#with capabilities}}
{{#if drop}}
      capabilitiesDrop:
{{#each drop}}
      - "{{.}}"
{{/each}}
{{/if}}
{{#if add}}
      capabilitiesAdd:
{{#each add}}
      - "{{.}}"
{{/each}}
{{/if}}
{{/with}}
{{/with}}
    jvm:
{{#if jvmJar}}
      jar: "{{jvmJar}}"
{{/if}}
{{#if jvmArgs}}
      options:
{{#each jvmArgs}}
      - "{{.}}"
{{/each}}
{{/if}}
    mount:
      hotReload: true
      resources:
{{#each resources}}
      - "{{.}}"
{{/each}}
{{#if emptyDirs}}
      emptyDirs:
{{#each emptyDirs}}
      - "{{.}}"
{{/each}}
{{/if}}
{{#if propertiesEnabled}}
    camel:
      properties:
{{#each properties}}
      - "{{.}}"
{{/each}}
{{/if}}
    environment:
      vars:
{{#each environment}}
      - {{.}}
{{/each}}
    health:
      enabled: true
{{#with health as | health |}}
{{#with health.liveness}}
      livenessProbeEnabled: {{enabled}}
{{#if enabled}}
{{#if schema}}
      livenessScheme: {{schema}}
{{/if}}
{{#if initialDelay}}
      livenessInitialDelay: {{initialDelay}}
{{/if}}
{{#if timeout}}
      livenessTimeout: {{timeout}}
{{/if}}
{{#if period}}
      livenessPeriod: {{period}}
{{/if}}
{{#if successThreshold}}
      livenessSuccessThreshold: {{successThreshold}}
{{/if}}
{{#if failureThreshold}}
      livenessFailureThreshold: {{failureThreshold}}
{{/if}}
{{#if probe}}
      livenessProbe: {{probe}}
{{/if}}
{{#if port}}
      livenessPort: {{port}}
{{/if}}
{{/if}}
{{/with}}
{{#with health.readiness}}
      readinessProbeEnabled: {{enabled}}
{{#if enabled}}
{{#if schema}}
      readinessScheme: {{schema}}
{{/if}}
{{#if initialDelay}}
      readinessInitialDelay: {{initialDelay}}
{{/if}}
{{#if timeout}}
      readinessTimeout: {{timeout}}
{{/if}}
{{#if period}}
      readinessPeriod: {{period}}
{{/if}}
{{#if successThreshold}}
      readinessSuccessThreshold: {{successThreshold}}
{{/if}}
{{#if failureThreshold}}
      readinessFailureThreshold: {{failureThreshold}}
{{/if}}
{{#if probe}}
      readinessProbe: {{probe}}
{{/if}}
{{#if port}}
      readinessPort: {{port}}
{{/if}}
{{/if}}
{{/with}}
{{#with health.startup}}
      startupProbeEnabled: {{enabled}}
{{#if enabled}}
{{#if schema}}
      startupScheme: {{schema}}
{{/if}}
{{#if initialDelay}}
      startupInitialDelay: {{initialDelay}}
{{/if}}
{{#if timeout}}
      startupTimeout: {{timeout}}
{{/if}}
{{#if period}}
      startupPeriod: {{period}}
{{/if}}
{{#if successThreshold}}
      startupSuccessThreshold: {{successThreshold}}
{{/if}}
{{#if failureThreshold}}
      startupFailureThreshold: {{failureThreshold}}
{{/if}}
{{#if probe}}
      startupProbe: {{probe}}
{{/if}}
{{#if port}}
      startupPort: {{port}}
{{/if}}
{{/if}}
{{/with}}
{{/with}}
{{#with container}}
  template:
    spec:
      containers:
      - securityContext:
          readOnlyRootFilesystem: {{readOnlyRootFilesystem}}
{{#if runAsGroup}}
          runAsGroup: {{runAsGroup}}
{{/if}}
        name: integration
{{#if args}}
        args:
{{#each args}}
        - "{{.}}"
{{/each}}
{{/if}}
{{/with}}

---
apiVersion: camel.apache.org/v1
kind: Integration
metadata:
  name: {{name}}
  labels:
    {{domainLabel}}: {{domainName}}
spec:
  replicas: {{replicas}}
  serviceAccountName: {{serviceAccountName}}
  traits:
    owner:
      targetLabels:
      - {{domainLabel}}
    container:
{{#with container}}      image: "{{image}}"
      imagePullPolicy: {{imagePullPolicy}}
{{#with limit as | limit |}}
{{#if limit.cpu}}
      limitCPU: {{limit.cpu}}
{{/if}}
{{#if limit.memory}}
      limitMemory: {{limit.memory}}
{{/if}}
{{/with}}
{{#with request as | request |}}
{{#if request.cpu }}
      requestCPU: {{request.cpu}}
{{/if}}
{{#if request.memory }}
      requestMemory: {{request.memory}}
{{/if}}
{{/with}}
{{/with}}
    jvm:
{{#if jvmJar}}
      jar: "{{jvmJar}}"
{{/if}}
{{#if jvmArgs}}
      options:
{{#each jvmArgs}}
      - "{{.}}"
{{/each}}
{{/if}}
    mount:
      hotReload: true
      resources:
{{#each resources}}
      - "{{.}}"
{{/each}}
{{#if emptyDirs}}
      emptyDirs:
{{#each emptyDirs}}
      - "{{.}}"
{{/each}}
{{/if}}
{{#if propertiesEnabled}}
    camel:
      properties:
{{#each properties}}
      - "{{.}}"
{{/each}}
{{/if}}
    environment:
      vars:
{{#each environment}}
      - {{.}}
{{/each}}

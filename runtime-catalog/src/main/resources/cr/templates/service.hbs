---
apiVersion: v1
kind: Service
metadata:
  name: {{name}}
  labels:
    camel.apache.org/integration: {{integrationName}}
    {{domainLabel}}: {{domainName}}
spec:
  selector:
    camel.apache.org/integration: {{integrationName}}
  ports:
  - name: http
    protocol: TCP
    port: 8080
    targetPort: 8080

{
  "name": "@netcracker/qip-schemas",
  "version": "0.2.29",
  "license": "Apache-2.0",
  "description": "Schemas definition for QIP",
  "scripts": {
    "build": "ts-node src/main/scripts/build.ts build",
    "clean": "ts-node src/main/scripts/build.ts clean",
    "prepublishOnly": "npm run build",
    "postpublish": "npm run clean",
    "test": "jest"
  },
  "files": [
    "assets",
    "types",
    "dist"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./assets/*": "./assets/*"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^14.1.1",
    "@nodelib/fs.walk": "^3.0.1",
    "@types/glob": "^9.0.0",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.1.0",
    "ajv": "^8.17.1",
    "glob": "^11.0.0",
    "jest": "^29.7.0",
    "jest-expect-message": "^1.1.3",
    "js-yaml": "^4.1.0",
    "json-schema-to-typescript": "^14.1.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "yaml": "^2.8.0"
  }
}

{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.lib.tsbuildinfo",
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "./src",
    "outDir": "./dist-lib/types",
    "composite": false,
    "types": ["vite/client"]
  },
  "include": ["src", "global-definitions.d.ts"],
  "exclude": [
    "src/__tests__",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "tests",
    "jest.config.ts",
    "vite.config.ts",
    "vite.config.lib.ts",
    "vite.config.lib.bundled.mts"
  ]
}

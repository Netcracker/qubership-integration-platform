{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "declaration": true,
    "target": "ES2020",
    "outDir": "dist",
    "lib": ["ES2020", "WebWorker"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vscode", "webpack-env", "jest", "mocha", "assert", "js-yaml", "yauzl"],
    "paths": {
      "@netcracker/qip-schemas": [
        "./node_modules/@netcracker/qip-schemas",
        "./node_modules/@netcracker/qip-ui/node_modules/@netcracker/qip-schemas"
      ],
      "@netcracker/qip-schemas/*": [
        "./node_modules/@netcracker/qip-schemas/*",
        "./node_modules/@netcracker/qip-ui/node_modules/@netcracker/qip-schemas/*"
      ]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests"]
}

{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "declaration": true,
    "target": "ES2020",
    "outDir": "dist",
    "lib": ["ES2020", "WebWorker"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vscode", "webpack-env", "jest", "mocha", "assert", "js-yaml", "yauzl"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests"]
}
